<%- include("partials/head", { title: "CityCare – About" }) %>
<%- include("partials/nav") %>

<main class="container">

  <!-- Page Header -->
  <section class="card header-card" style="text-align:center;">
    <img class="logo" src="/images/logo.png" alt="CityCare Medical Center" />
    <h1>About CityCare Medical Center</h1>
    <p class="subtitle">Compassionate, patient-centered care for our community</p>
  </section>

  <!-- Hero -->
  <section class="card hero-card" aria-label="CityCare hero image">
    <img
      class="hero-img"
      src="https://images.unsplash.com/photo-1586773860418-d37222d8fce3?auto=format&fit=crop&w=1600&q=80"
      alt="Modern hospital building"
    />
    <div class="hero-overlay"></div>
    <div class="hero-text">
      <h2>Healthcare you can trust</h2>
      <p>We focus on quality medical services, clear communication, and a welcoming experience.</p>
    </div>
  </section>

  <!-- Mission & Vision -->
  <section class="card form-card">
    <div class="section">
      <div class="section-title"><h2>Our Mission</h2></div>
      <p class="about-text">
        At CityCare Medical Center, our mission is to provide high-quality healthcare that improves the
        health and well-being of the people in our community.
      </p>
      <p class="about-text">
        We treat every patient with respect, compassion, and professionalism. We explain treatments in
        simple terms and support patients through every step.
      </p>
    </div>

    <div class="section">
      <div class="section-title"><h2>Our Vision</h2></div>
      <p class="about-text">
        To be a trusted medical center known for excellent patient care, modern technology,
        and a strong connection to the community.
      </p>
    </div>
  </section>

  <!-- Values -->
  <section class="card form-card">
    <div class="section">
      <div class="section-title"><h2>Our Core Values</h2></div>

      <div class="values-grid">
        <div class="value-box">
          <div class="value-icon">❤</div>
          <h3>Compassion</h3>
          <p>We care about people and treat every patient kindly.</p>
        </div>

        <div class="value-box">
          <div class="value-icon">🛡</div>
          <h3>Excellence</h3>
          <p>We aim for high standards in every service we provide.</p>
        </div>

        <div class="value-box">
          <div class="value-icon">👥</div>
          <h3>Teamwork</h3>
          <p>Doctors, nurses, and staff work together for better care.</p>
        </div>

        <div class="value-box">
          <div class="value-icon">🏆</div>
          <h3>Integrity</h3>
          <p>We act honestly and responsibly in every decision.</p>
        </div>

        <div class="value-box">
          <div class="value-icon">⏰</div>
          <h3>Accessibility</h3>
          <p>We want healthcare to be available when people need it.</p>
        </div>

        <div class="value-box">
          <div class="value-icon">🩺</div>
          <h3>Innovation</h3>
          <p>We use updated tools and modern medical practices.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="card stats-card" aria-label="CityCare stats">
    <div class="stats-grid">
      <div class="stat">
        <div class="stat-num">30+</div>
        <div class="stat-label">Years of Service</div>
      </div>
      <div class="stat">
        <div class="stat-num">150+</div>
        <div class="stat-label">Medical Professionals</div>
      </div>
      <div class="stat">
        <div class="stat-num">50,000+</div>
        <div class="stat-label">Patients Annually</div>
      </div>
      <div class="stat">
        <div class="stat-num">24/7</div>
        <div class="stat-label">Emergency Care</div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="card form-card">
    <div class="section">
      <div class="section-title"><h2>Meet Our Leadership</h2></div>
      <p class="about-text center">
        Our leadership team supports our medical staff and patient experience.
      </p>

      <div class="team-grid">
        <div class="team-card">
          <img class="team-img"
               src="https://images.unsplash.com/photo-1550831107-1553da8c8464?auto=format&fit=crop&w=900&q=80"
               alt="Doctor portrait" />
          <div class="team-body">
            <h3>Dr. Michael Chen</h3>
            <p class="team-role">Chief Medical Officer</p>
            <p class="team-desc">20+ years of experience in Internal Medicine.</p>
          </div>
        </div>

        <div class="team-card">
          <img class="team-img"
               src="https://images.unsplash.com/photo-1607746882042-944635dfe10e?auto=format&fit=crop&w=900&q=80"
               alt="Doctor portrait" />
          <div class="team-body">
            <h3>Dr. Sarah Williams</h3>
            <p class="team-role">Director of Emergency Services</p>
            <p class="team-desc">Specialized in emergency medicine and trauma care.</p>
          </div>
        </div>

        <div class="team-card">
          <img class="team-img"
               src="https://images.unsplash.com/photo-1579684385127-1ef15d508118?auto=format&fit=crop&w=900&q=80"
               alt="Medical team" />
          <div class="team-body">
            <h3>Our Medical Team</h3>
            <p class="team-role">Dedicated Healthcare Professionals</p>
            <p class="team-desc">A team committed to exceptional patient care.</p>
          </div>
        </div>
      </div>
    </div>

    <div class="section">
      <div class="section-title"><h2>Facilities & Services</h2></div>

      <div class="two-col-list">
        <ul>
          <li>24/7 Emergency Department</li>
          <li>Advanced Diagnostic Imaging</li>
          <li>Surgical Services</li>
          <li>Intensive Care Unit</li>
        </ul>
        <ul>
          <li>Cardiology & Heart Center</li>
          <li>Women’s Health Services</li>
          <li>Pediatric Care</li>
          <li>Physical Rehabilitation</li>
        </ul>
      </div>
    </div>
  </section>

</main>

<%- include("partials/footer") %>
